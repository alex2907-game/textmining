import PyPDF2
import spacy

# Step 1: Load the spaCy English model
nlp = spacy.load("en_core_web_sm")

# Step 2: Provide PDF file path
pdf_path = "sample.pdf"

# Step 3: Extract text from PDF
text = ""

with open(pdf_path, "rb") as file:
    reader = PyPDF2.PdfReader(file)
    
    for page in reader.pages:
        page_text = page.extract_text()
        if page_text:
            text += page_text

# Step 4: Process text using spaCy NLP
doc = nlp(text)

# Step 5: Print sentences
print("\nSentences in Document:\n")
for sent in doc.sents:
    print(sent.text)

# Step 6: Extract named entities
print("\nEntities Found:\n")
for ent in doc.ents:
    print(ent.text, "-", ent.label_)

# Step 7: Extract simple subject-object relations
print("\nRelations (Subject -> Object):\n")

subject = None

for token in doc:
    if token.dep_ == "nsubj":
        subject = token.text
        
    if token.dep_ == "dobj" and subject:
        print(subject, "->", token.text)
