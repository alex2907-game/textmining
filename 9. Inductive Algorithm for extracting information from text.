import PyPDF2
import spacy

# Load NLP model
nlp = spacy.load("en_core_web_sm")

# Step 1: PDF file path
pdf_path = "file2.pdf"

# Step 2: Extract text from PDF
text = ""
with open(pdf_path, "rb") as file:
    reader = PyPDF2.PdfReader(file)
    for page in reader.pages:
        text += page.extract_text()

# Step 3: Process extracted text
doc = nlp(text)

print("Extracted Relations:\n")

# Step 4: Apply simple inductive pattern
for sent in doc.sents:
    person = None
    org = None

    for ent in sent.ents:
        if ent.label_ == "PERSON":
            person = ent.text
        if ent.label_ == "ORG":
            org = ent.text

    if person and org:
        print(person, "-> works at ->", org)
